{
  "name": "green-hope-initiative",
  "version": "1.0.0",
  "description": "Using AI to find the best locations for planting trees, analyze environmental risks, and raise funds for reforestation projects.",
  "main": "index.tsx",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "lint": "tsc --noEmit",
    "start": "node dist/server.cjs"
  },
  "author": "AI Studio",
  "license": "ISC",
  "dependencies": {
    "@google/genai": "^1.17.0",
    "@types/file-saver": "^2.0.7",
    "express": "^5.2.1",
    "file-saver": "^2.0.5",
    "lucide-react": "^1.18.0",
    "marked": "^14.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "vite": "^6.4.3"
  }
}
